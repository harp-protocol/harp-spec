{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harp-protocol.org/schemas/extensions/harp-requested-actions.json",
  "title": "HARP Extension: Requested Actions",
  "description": "Schema for the org.harp.requestedActions extension. Allows enforcers to specify UI actions within an artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "actions"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Extension schema version. Must be 1."
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/actionItem"
      },
      "description": "Ordered list of action items to present to the approver."
    }
  },
  "$defs": {
    "actionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "caption", "decision"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier for this action within the extension instance."
        },
        "caption": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable button label."
        },
        "style": {
          "type": "string",
          "enum": ["primary", "secondary", "danger"],
          "default": "secondary",
          "description": "Visual style hint. Unknown values normalize to 'secondary'."
        },
        "decision": {
          "type": "string",
          "enum": ["approve", "reject"],
          "description": "HARP Core decision mapping."
        }
      }
    }
  }
}
